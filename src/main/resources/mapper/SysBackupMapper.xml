<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.app.springbootcargovision.mapper.SysBackupMapper">

    <resultMap type="SysBackup" id="SysBackupResult">
        <id property="id" column="id" />
        <result property="name" column="name" />
        <result property="path" column="path" />
        <result property="size" column="size" />
        <result property="createTime" column="create_time" />
        <result property="status" column="status" />
        <result property="errorMsg" column="error_msg" />
        <result property="version" column="version" />
        <result property="operator" column="operator" />
        <result property="delFlag" column="del_flag" />
    </resultMap>

    <sql id="selectBackupVo">
        select id, name, path, size, create_time, status, error_msg, version, operator, del_flag 
        from sys_backup
    </sql>

    <select id="selectBackupList" resultMap="SysBackupResult">
        <include refid="selectBackupVo"/>
        where del_flag = 0
        order by create_time desc
    </select>

    <select id="selectBackupById" parameterType="Long" resultMap="SysBackupResult">
        <include refid="selectBackupVo"/>
        where id = #{id}
    </select>

    <insert id="insertBackup" parameterType="SysBackup" useGeneratedKeys="true" keyProperty="id">
        insert into sys_backup (
        <if test="name != null and name != ''">name,</if>
        <if test="path != null and path != ''">path,</if>
        <if test="size != null">size,</if>
        <if test="status != null and status != ''">status,</if>
        <if test="errorMsg != null and errorMsg != ''">error_msg,</if>
        <if test="version != null and version != ''">version,</if>
        <if test="operator != null and operator != ''">operator,</if>
        <if test="delFlag != null">del_flag,</if>
            create_time
        ) values (
        <if test="name != null and name != ''">#{name},</if>
        <if test="path != null and path != ''">#{path},</if>
        <if test="size != null">#{size},</if>
        <if test="status != null and status != ''">#{status},</if>
        <if test="errorMsg != null and errorMsg != ''">#{errorMsg},</if>
        <if test="version != null and version != ''">#{version},</if>
        <if test="operator != null and operator != ''">#{operator},</if>
        <if test="delFlag != null">#{delFlag},</if>
            sysdate()
        )
    </insert>

    <update id="updateBackup" parameterType="SysBackup">
        update sys_backup
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="path != null">path = #{path},</if>
            <if test="size != null">size = #{size},</if>
            <if test="status != null">status = #{status},</if>
            <if test="errorMsg != null">error_msg = #{errorMsg},</if>
            <if test="version != null">version = #{version},</if>
            <if test="operator != null">operator = #{operator},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteBackupById" parameterType="Long">
        delete from sys_backup where id = #{id}
    </delete>

</mapper>
